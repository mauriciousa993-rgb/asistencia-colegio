# Configuración de MongoDB
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/asistencia-colegio?retryWrites=true&w=majority

# Configuración de JWT
JWT_SECRET=tu_secreto_super_seguro_aqui_cambia_esto_en_produccion

# Puerto (Render asigna automáticamente, pero puedes definirlo para desarrollo local)
PORT=5000

# Tiempo maximo para encontrar MongoDB (en milisegundos)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Ejecutar backup completo al arrancar (recomendado false en Render)
STARTUP_STUDENT_BACKUP=false

# Entorno
NODE_ENV=production
